# PyPI credentials for log-center-sdk publishing
# Copy to config/pypi.env and fill in your token.
# config/pypi.env is gitignored — never commit secrets.

LOG_CENTER_PYPI_USERNAME=__token__
LOG_CENTER_PYPI_TOKEN=replace_with_your_pypi_api_token
LOG_CENTER_PYPI_REPOSITORY_URL=https://upload.pypi.org/legacy/
